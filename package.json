{
  "name": "nte-leveling",
  "productName": "NTE Leveling Calculator",
  "version": "0.3.6",
  "description": "Quality-of-life level calculator & resource checker for Neverness To Everness",
  "author": "Alex168163",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "gen:data": "node scripts/parse-md.mjs",
    "predev": "node scripts/parse-md.mjs",
    "dev": "vite",
    "prebuild": "node scripts/parse-md.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "node scripts/parse-md.mjs && concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && electron-builder",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "package:win": "npm run build && electron-packager . \"NTE Leveling Calculator\" --platform=win32 --arch=x64 --out=release --overwrite --app-version=0.1.0 --ignore=\"(/release|/\\.git|/src|/scripts|/public|/\\.vite)\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.alex168163.nteleveling",
    "productName": "NTE Leveling Calculator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
